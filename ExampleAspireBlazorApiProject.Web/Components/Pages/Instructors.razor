@page "/instructors"
@inject InstructorApiClient InstructorApi
@rendermode InteractiveServer

@code{
    private bool _dataLoading;
    private List<InstructorModel> _instructors = [];
    private MudDataGrid<InstructorModel> _mudDataGrid = default!;

    private MudDialog _createDialog = default!;
    private MudDialog _editDialog = default!;
    private MudDialog _infoDialog = default!;
    private MudDialog _deleteDialog = default!;

    private MudForm _createForm;
    private MudForm _editForm;
    private MudForm _deleteForm;

    private bool _createFormSuccess;
    private bool _editFormSuccess;
    
    private InstructorModel? _editInstructor;
    private InstructorModel? _deleteInstructor;
    private InstructorModel? _inspectInstructor;
    private InstructorModel _newInstructor = new();
    
    protected override void OnInitialized()
    {
        base.OnInitialized();
        _ = LoadAllDataAsync();
    }
    
    // LOAD
    private async Task LoadAllDataAsync()
    {
        _dataLoading = true;
        StateHasChanged();
        
        _instructors = await InstructorApi.GetAllInstructorsAsync() ?? [];
        
        _dataLoading = false;
        StateHasChanged();
    }
    
    // MODALS
    private async Task OnShowModal(MudDialog? dialog)
    {
        if (dialog is null) return;
        await dialog.ShowAsync(options: dialog == _infoDialog ? DialogData.DialogInfoOptions : DialogData.DialogDefaultOptions);
    }
    
    private async Task OnHideModal(MudDialog? dialog)
    {
        if (dialog is null) return;
        await dialog.CloseAsync();
    }
    
    // CREATE
    private async Task HandleCreateAsync()
    {
        await _createForm.ValidateAsync();
        if (!_createForm.IsValid) return;
        
        var newInstructor = await InstructorApi.CreateInstructorAsync(_newInstructor);
        if (newInstructor is not null)
            _instructors.Add(newInstructor);
        
        _newInstructor = new();
        await OnHideModal(_createDialog);
        await _mudDataGrid.ReloadServerData();
    }
    
    // EDIT
    private async Task OnShowEditModal(InstructorModel instructor)
    {
        _editInstructor = new(instructor);
        await OnShowModal(_editDialog);
    }
    
    private async Task ConfirmEditAsync()
    {
        if (_editInstructor is null) return;
        
        await _editForm.ValidateAsync();
        if (!_editForm.IsValid) return;

        var updated = await InstructorApi.UpdateInstructorAsync(_editInstructor);
        if (!updated) return;
        
        var drivingSchoolToUpdate = _instructors.FirstOrDefault(x => x.Id == _editInstructor.Id);
        if (drivingSchoolToUpdate is null) return;
        
        drivingSchoolToUpdate.FirstName = _editInstructor.FirstName;
        drivingSchoolToUpdate.LastName = _editInstructor.LastName;
        drivingSchoolToUpdate.Mail = _editInstructor.Mail;
        drivingSchoolToUpdate.Phone = _editInstructor.Phone;

        await OnHideModal(_editDialog);
        await _mudDataGrid.ReloadServerData();
        _editInstructor = null;
    }
    
    // DELETE
    private async Task OnShowDeleteModal(InstructorModel instructor)
    {
        _deleteInstructor = new(instructor);
        await OnShowModal(_deleteDialog);
    }
    
    private async Task OnRequestDeleteAsync()
    {
        if (_deleteInstructor is null) return;
        
        var deleted = await InstructorApi.DeleteInstructorAsync(_deleteInstructor.Id);
        if (!deleted) return;
        
        var remove = _instructors.FirstOrDefault(x => x.Id == _deleteInstructor.Id);
        if(remove is not null)
            _instructors.Remove(remove);
        
        await OnHideModal(_deleteDialog);
        await _mudDataGrid.ReloadServerData();
    }
    
    // INFO
    private async Task OnShowInfoModal(InstructorModel instructor)
    {
        _inspectInstructor = new(instructor);
        await OnShowModal(_infoDialog);
    }
}

<PageTitle>Fahrlehrer</PageTitle>

<MudPaper Class="d-flex flex-row align-center mud-theme-dark pa-4 ma-4" Elevation="1">
    <MudPaper Class="d-flex flex-column mud-theme-dark" Elevation="0">
        <MudText Typo="Typo.h5" Color="Color.Secondary">Fahrlehrer</MudText>
        <MudText Typo="Typo.body1">Hier sind alle Fahrlehrer aufgelistet, die unterrichten dürfen.</MudText>
    </MudPaper>
    <MudSpacer/>
    <MudButton
        Size="Size.Small"
        EndIcon="@Icons.Material.Filled.Add"
        Variant="Variant.Outlined"
        Color="Color.Primary"
        OnClick="() => OnShowModal(_createDialog)">
        Eintragen
    </MudButton>
</MudPaper>

@if (_dataLoading)
{
    <MudPaper Class="mud-theme-dark pa-4 ma-4" Elevation="1">
        <MudProgressLinear Color="Color.Primary" Indeterminate="true"/>
    </MudPaper>
}
else
{
    <div class="@(_instructors.Count == 0 ? "d-none" : "")">
        <MudPaper Class="mud-theme-dark pa-4 ma-4" Elevation="1">
            <MudDataGrid 
                @ref="_mudDataGrid" 
                Items="@_instructors" 
                Bordered="false"
                Dense="true"
                RowsPerPage="10"
                SortMode="SortMode.Multiple"
                Hover="true"
                Loading="@_dataLoading"
            >
                <Columns>
                    <PropertyColumn Property="x => x.Id" Title="ID" />
                    <PropertyColumn Property="x => x.FullName" Title="Vor- Nachname" />
                    <PropertyColumn Property="x => x.Mail" Title="E-Mail" />
                    <TemplateColumn Title="Telefon">
                        <CellTemplate>
                            @if (context.Item.Phone != null && !string.IsNullOrWhiteSpace(context.Item.Phone))
                            {
                                <MudText Typo="Typo.body2">@context.Item.Phone</MudText>
                            }
                            else
                            {
                                <MudText Typo="Typo.body2" Style="@($"color:{Colors.Gray.Darken1};")"><i>keine Angabe</i></MudText>
                            }
                        </CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn Title="Zugewiesene Kurse">
                        <CellTemplate>
                            @if (context.Item.TheoryLessons.Count > 0)
                            {
                                <MudChip T="string" 
                                         Size="Size.Medium" 
                                         Variant="Variant.Text"
                                         Color="Color.Success">
                                    @context.Item.TheoryLessons.Count
                                </MudChip>
                            }
                            else
                            {
                                <MudText Typo="Typo.body2" Style="@($"color:{Colors.Gray.Darken1};")"><i>Keine</i></MudText>
                            }
                        </CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn>
                        <CellTemplate>
                            <MudTooltip Text="Ansehen" ShowOnFocus="false">
                                <MudIconButton
                                    Variant="Variant.Outlined"
                                    Color="Color.Info"
                                    Size="Size.Small"
                                    Icon="@Icons.Material.Filled.Info"
                                    OnClick="() => OnShowInfoModal(context.Item)"
                                    Class="mr-2"
                                    aria-label="Ansehen"/>
                            </MudTooltip>
                            <MudTooltip Text="Bearbeiten" ShowOnFocus="false">
                                <MudIconButton
                                    Variant="Variant.Outlined"
                                    Color="Color.Warning"
                                    Size="Size.Small"
                                    Icon="@Icons.Material.Filled.Edit"
                                    OnClick="() => OnShowEditModal(context.Item)"
                                    Class="mr-2"
                                    aria-label="Bearbeiten"/>
                            </MudTooltip>
                            <MudTooltip Text="Löschen" ShowOnFocus="false">
                                <MudIconButton
                                    Variant="Variant.Outlined"
                                    Color="Color.Error"
                                    Size="Size.Small"
                                    Icon="@Icons.Material.Filled.Delete"
                                    OnClick="() => OnShowDeleteModal(context.Item)"
                                    aria-label="Löschen"/>
                            </MudTooltip>
                        </CellTemplate>
                    </TemplateColumn>
                </Columns>
                <PagerContent>
                    <MudDataGridPager />
                </PagerContent>
            </MudDataGrid>
        </MudPaper>
    </div>
    
    if (_instructors.Count == 0)
    {
        <MudPaper Class="mud-theme-dark pa-4 ma-4" Elevation="1">
            <MudAlert Severity="Severity.Info" ContentAlignment="HorizontalAlignment.Center">Keine Daten vorhanden.</MudAlert>
        </MudPaper>
    }
}

<MudDialog @ref="_createDialog">
    <TitleContent>
        <MudText Typo="Typo.h6">Fahrlehrer eintragen</MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_createForm" @bind-IsValid="@_createFormSuccess">
            <MudPaper Class="mud-theme-dark pa-4" Elevation="1">
                <MudTextField T="string"
                              Class="mb-4"
                              Variant="Variant.Text"
                              @bind-Value="_newInstructor.FirstName"
                              ShrinkLabel
                              Label="Vorname"
                              For="@(() => _newInstructor.FirstName)"
                              Immediate="true"/>
                <MudTextField T="string"
                              Class="mb-4"
                              Variant="Variant.Text"
                              @bind-Value="_newInstructor.LastName"
                              ShrinkLabel
                              Label="Nachname"
                              For="@(() => _newInstructor.LastName)"
                              Immediate="true"/>
                <MudTextField T="string"
                              Class="mb-4"
                              ShrinkLabel
                              Variant="Variant.Text"
                              @bind-Value="_newInstructor.Mail"
                              Label="E-Mail"
                              For="@(() => _newInstructor.Mail)"
                              Immediate="true"/>
                <MudTextField Class="mb-4" ShrinkLabel @bind-Value="_newInstructor.Phone" Label="Telefon" Variant="Variant.Text"/>
            </MudPaper>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Error" OnClick="() => OnHideModal(_createDialog)">Abbrechen</MudButton>
        <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Secondary" OnClick="HandleCreateAsync">Eintragen</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @ref="_editDialog">
    <TitleContent>
        <MudText Typo="Typo.h6">Fahrlehrer bearbeiten</MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_editForm" @bind-IsValid="@_createFormSuccess">
            <MudPaper Class="mud-theme-dark pa-4" Elevation="1">
                <MudTextField T="string"
                              Class="mb-4"
                              Variant="Variant.Text"
                              @bind-Value="_editInstructor!.FirstName"
                              ShrinkLabel
                              Label="Vorname"
                              For="@(() => _editInstructor!.FirstName)"
                              Immediate="true"/>
                <MudTextField T="string"
                              Class="mb-4"
                              Variant="Variant.Text"
                              @bind-Value="_editInstructor!.LastName"
                              ShrinkLabel
                              Label="Nachname"
                              For="@(() => _editInstructor!.LastName)"
                              Immediate="true"/>
                <MudTextField T="string"
                              Class="mb-4"
                              ShrinkLabel
                              Variant="Variant.Text"
                              @bind-Value="_editInstructor!.Mail"
                              Label="E-Mail"
                              For="@(() => _editInstructor!.Mail)"
                              Immediate="true"/>
                <MudTextField Class="mb-4" ShrinkLabel @bind-Value="_editInstructor!.Phone" Label="Telefon" Variant="Variant.Text"/>
            </MudPaper>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Error" OnClick="() => OnHideModal(_editDialog)">Abbrechen</MudButton>
        <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Secondary" OnClick="ConfirmEditAsync">Änderungen speichern</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @ref="_deleteDialog">
    <TitleContent>
        <MudText Typo="Typo.h6">Fahrlehrer löschen</MudText>
    </TitleContent>
    <DialogContent>
        <MudPaper Class="mud-theme-dark pa-4" Elevation="1">
            <MudText>Bist du sicher, dass du den Fahrlehrer @_deleteInstructor?.FullName löschen möchtest?</MudText>
        </MudPaper>
    </DialogContent>
    <DialogActions>
        <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Error" OnClick="() => OnHideModal(_deleteDialog)">Nein</MudButton>
        <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Secondary" OnClick="OnRequestDeleteAsync">Ja</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @ref="_infoDialog">
    <TitleContent>
        <MudText Typo="Typo.h6">@_inspectInstructor!.FullName | Informationen</MudText>
    </TitleContent>
    <DialogContent>
        <MudPaper Class="mud-theme-dark pa-4" Elevation="1">
            <MudListSubheader>
                Zugewiesene Kurse:
            </MudListSubheader>
            @if (_inspectInstructor!.TheoryLessons.Any())
            {
                foreach (var lesson in _inspectInstructor.TheoryLessons)
                {
                    <MudList T="string" ReadOnly="true">
                        <MudListItem T="string"
                                     Dense="true"
                                     Text="@lesson.Name"
                                     SecondaryText="@lesson.Topic"/>
                    </MudList>
                }
            }
            else
            {
                <MudText Typo="Typo.body2" Style="@($"color:{Colors.Gray.Darken1};")"><i>Unterrichtet zurzeit keinerlei Kurse.</i></MudText>
            }
        </MudPaper>
    </DialogContent>
    <DialogActions>
        <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info" OnClick="() => OnHideModal(_infoDialog)">Ok</MudButton>
    </DialogActions>
</MudDialog>