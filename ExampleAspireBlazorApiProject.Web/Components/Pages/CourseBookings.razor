@page "/bookings"
@inject CourseBookingApiClient CourseBookingApi
@inject StudentApiClient StudentApi
@inject TheoryLessonApiClient TheoryLessonApi
@rendermode InteractiveServer

@code{
    private bool _dataLoading;
    private List<CourseBookingModel> _courseBookings = [];
    private List<StudentModel> _students = [];
    private List<TheoryLessonModel> _lessons = [];
    private MudDataGrid<CourseBookingModel> _mudDataGrid = default!;

    private MudDialog _createDialog = default!;
    private MudDialog _deleteDialog = default!;
    
    private CourseBookingModel? _deleteCourseBooking;
    private CourseBookingModel _newCourseBooking = new();
    
    protected override void OnInitialized()
    {
        base.OnInitialized();
        _ = LoadAllDataAsync();
    }
    
    // LOAD
    private async Task LoadAllDataAsync()
    {
        _dataLoading = true;
        StateHasChanged();
        
        _courseBookings = await CourseBookingApi.GetAllCourseBookingsAsync() ?? [];
        _students = await StudentApi.GetAllStudentsAsync() ?? [];
        _lessons = await TheoryLessonApi.GetAllLessonsAsync() ?? [];
        
        _dataLoading = false;
        StateHasChanged();
    }
    
    // MODALS
    private async Task OnShowModal(MudDialog? dialog)
    {
        if (dialog is null) return;
        await dialog.ShowAsync(options: DialogData.DialogDefaultOptions);
    }
    
    private async Task OnHideModal(MudDialog? dialog)
    {
        if (dialog is null) return;
        await dialog.CloseAsync();
    }
}

<PageTitle>Kursbuchungen</PageTitle>

<MudPaper Class="d-flex flex-row align-center mud-theme-dark pa-4 ma-4" Elevation="1">
    <MudPaper Class="d-flex flex-column mud-theme-dark" Elevation="0">
        <MudText Typo="Typo.h5" Color="Color.Secondary">Kursbuchungen</MudText>
        <MudText Typo="Typo.body1">Hier sind alle Kurse aufgelistet, die eine Buchung aufweisen.</MudText>
    </MudPaper>
    <MudSpacer/>
    <MudButton
        Size="Size.Small"
        EndIcon="@Icons.Material.Filled.Add"
        Variant="Variant.Outlined"
        Color="Color.Primary"
        OnClick="() => OnShowModal(_createDialog)">
        Neue Buchung
    </MudButton>
</MudPaper>

@if (_dataLoading)
{
    <MudPaper Class="mud-theme-dark pa-4 ma-4" Elevation="1">
        <MudProgressLinear Color="Color.Primary" Indeterminate="true"/>
    </MudPaper>
}
else
{
    <div class="@(_courseBookings.Count == 0 ? "d-none" : "")">
        <MudPaper Class="mud-theme-dark pa-4 ma-4" Elevation="1">
            <MudDataGrid 
                @ref="_mudDataGrid" 
                Items="@_courseBookings" 
                Bordered="false"
                Dense="true"
                RowsPerPage="10"
                SortMode="SortMode.Multiple"
                Hover="true"
                Loading="@_dataLoading"
            >
                <Columns>
                    <PropertyColumn Property="x => x.Id" Title="ID" />
                    <PropertyColumn Property="x => x.BookingDate" Title="Buchungsdatum" />
                    <TemplateColumn Title="Fahrschüler">
                        <CellTemplate>
                            @if (context.Item.Student != null)
                            {
                                <MudText Typo="Typo.body2">@context.Item.Student.FullName</MudText>
                            }
                            else
                            {
                                <MudText Typo="Typo.body2" Color="Color.Error"><i>Nicht zugewiesen</i></MudText>
                            }
                        </CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn Title="Kurs">
                        <CellTemplate>
                            @if (context.Item.TheoryLesson != null)
                            {
                                <MudText Typo="Typo.body2">@context.Item.TheoryLesson.Name | @context.Item.TheoryLesson.Topic</MudText>
                            }
                            else
                            {
                                <MudText Typo="Typo.body2" Color="Color.Error"><i>Nicht zugewiesen</i></MudText>
                            }
                        </CellTemplate>
                    </TemplateColumn>
                </Columns>
                <PagerContent>
                    <MudDataGridPager />
                </PagerContent>
            </MudDataGrid>
        </MudPaper>
    </div>
    
    if (_courseBookings.Count == 0)
    {
        <MudPaper Class="mud-theme-dark pa-4 ma-4" Elevation="1">
            <MudAlert Severity="Severity.Info" ContentAlignment="HorizontalAlignment.Center">Keine Daten vorhanden.</MudAlert>
        </MudPaper>
    }
}