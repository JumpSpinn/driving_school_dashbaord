@page "/students"
@using System.Text.RegularExpressions
@using ExampleAspireBlazorApiProject.Shared.Models
@using ExampleAspireBlazorApiProject.Web.Apis
@inject StudentApiClient StudentApiClient
@inject DrivingSchoolApiClient DrivingSchoolApiClient
@rendermode InteractiveServer

@code {
    private bool _dataLoading;
    private List<StudentModel> _students = [];
    private MudDataGrid<StudentModel> _mudDataGrid = default!;
    
    private readonly DialogOptions _dialogOptions = new()
    {
        MaxWidth = MaxWidth.Small,
        FullWidth = true,
        BackdropClick = true,
        CloseOnEscapeKey = true,
        BackgroundClass = "dialog_backdrop_blur"
    };
    
    private MudDialog _createDialog = default!;
    private MudDialog _deleteDialog = default!;
    private MudDialog _editDialog = default!;
    private string _modalError = string.Empty; // TODO: reimplement
    
    private List<DrivingSchoolModel> _drivingSchools = [];
    private StudentModel? _editStudent;
    private StudentModel? _deleteStudent;
    private StudentModel _newStudent = new();
    
    protected override void OnInitialized()
    {
        base.OnInitialized();
        _ = LoadAllStudentsAsync();
    }
    
    // VALIDATION
    private bool ValidateCreateStudent(StudentModel validateStudent)
    {
        _modalError = string.Empty;
        
        if (string.IsNullOrWhiteSpace(validateStudent.FirstName))
            _modalError = "Vorname muss angegeben werden!";
        else if (validateStudent.FirstName.Length < 3)
            _modalError = "Vorname muss mindestens 3 Zeichen lang sein!";
        else if (string.IsNullOrWhiteSpace(validateStudent.LastName))
            _modalError = "Nachname muss angegeben werden";
        else if (validateStudent.LastName.Length < 3)
            _modalError = "Nachname muss mindestens 3 Zeichen lang sein!";
        else if (string.IsNullOrWhiteSpace(validateStudent.Mail))
            _modalError = "E-Mail muss angegeben werden!";
        else if (!validateStudent.Mail.Contains("@"))
            _modalError = "Ungültige E-Mail Adresse!";
        else if (!string.IsNullOrWhiteSpace(validateStudent.Phone))
        {
            var isMatch = Regex.IsMatch(validateStudent.Phone, @"^\d+$");
            if (!isMatch)
                _modalError = "Ungültige Telefonnummer. Darf nur aus Zahlen bestehen!";
        }

        return string.IsNullOrWhiteSpace(_modalError);
    }
    
    // LOAD
    private async Task LoadAllStudentsAsync()
    {
        _dataLoading = true;
        StateHasChanged();

        _students = await StudentApiClient.GetAllStudentsAsync() ?? [];
        _drivingSchools = await DrivingSchoolApiClient.GetAllDrivingSchoolsAsync() ?? [];
        
        _dataLoading = false;
        StateHasChanged();
    }
    
    // MODALS
    private async Task OnShowModal(MudDialog? dialog)
    {
        if (dialog is null) return;
        
        if(dialog == _createDialog)
            _newStudent = new();
        
        await dialog.ShowAsync(options: _dialogOptions);
    }
    
    private async Task OnHideModal(MudDialog? dialog)
    {
        if (dialog is null) return;
        await dialog.CloseAsync();
    }
    
    // CREATE
    private async Task HandleCreateDriverAsync()
    {
        if (!ValidateCreateStudent(_newStudent)) return;
        
        var newStudent = await StudentApiClient.CreateStudentAsync(_newStudent);
        if (newStudent is not null)
            _students.Add(newStudent);
        
         _newStudent = new();
        await OnHideModal(_createDialog);
        await _mudDataGrid.ReloadServerData();
    }
    
    // EDIT
    private void OnShowEditModal(StudentModel student)
    {
        _modalError = string.Empty;
        _editStudent = new(student);
        _ = OnShowModal(_editDialog);
    }
    
    private async Task ConfirmEditDrivingSchoolAsync()
    {
        if (_editStudent is null) return;
        if (!ValidateCreateStudent(_editStudent)) return;

        var updated = await StudentApiClient.UpdateStudentAsync(_editStudent);
        if (!updated)
        {
            _modalError = $"Fahrschüler {_editStudent.FirstName} {_editStudent.LastName} konnte nicht bearbeitet werden!";
            return;
        }
        
        var studentToUpdate = _students.FirstOrDefault(x => x.Id == _editStudent.Id);
        if (studentToUpdate is null)
        {
            _modalError = "Der zu bearbeitende Fahrschüler ist nicht bekannt!";
            return;
        }
        
        studentToUpdate.FirstName = _editStudent.FirstName;
        studentToUpdate.LastName = _editStudent.LastName;
        studentToUpdate.Mail = _editStudent.Mail;
        studentToUpdate.Phone = _editStudent.Phone;
        studentToUpdate.DrivingSchoolId = _editStudent.DrivingSchoolId;
        studentToUpdate.IsActive = _editStudent.IsActive;
        
        await OnHideModal(_editDialog);
        await _mudDataGrid.ReloadServerData();
        _editStudent = null;
    }
    
    // DELETE
    private void OnShowDeleteModal(StudentModel student)
    {
        _modalError = string.Empty;
        _deleteStudent = new(student);
        _ = OnShowModal(_deleteDialog);
    }
    
    private async Task OnRequestDeleteDriverAsync()
    {
        if (_deleteStudent is null) return;
        
        var deleted = await StudentApiClient.DeleteStudentAsync(_deleteStudent.Id);
        if (!deleted) return;
        
        var remove = _students.FirstOrDefault(x => x.Id == _deleteStudent.Id);
        if(remove is not null)
            _students.Remove(remove);
        
        await _mudDataGrid.ReloadServerData();
        await OnHideModal(_deleteDialog);
    }
    
    // SCHOOL
    private DrivingSchoolModel? GetDrivingSchool(int id) 
        => _drivingSchools.FirstOrDefault(s => s.Id == id);
    
    private string GetDrivingSchoolName(int? schoolId)
    {
        if (schoolId is null or 0) return "Keine Zuweisung";

        var school = GetDrivingSchool((int)schoolId);
        return school?.Name ?? "Unbekannte Fahrschule";
    }
}

<PageTitle>Fahrschüler</PageTitle>

<MudPaper Class="d-flex flex-row align-center mud-theme-dark pa-4 ma-4" Elevation="1">
    <MudPaper Class="d-flex flex-column mud-theme-dark" Elevation="0">
        <MudText Typo="Typo.h5" Color="Color.Secondary">Fahrschüler</MudText>
        <MudText Typo="Typo.body1">Hier sind alle Fahrschüler aufgelistet, die im System eingetragen wurden.</MudText>
    </MudPaper>
    <MudSpacer/>
    <MudButton
        Size="Size.Small"
        EndIcon="@Icons.Material.Filled.Add"
        Variant="Variant.Outlined"
        Color="Color.Primary"
        OnClick="() => OnShowModal(_createDialog)">
        Eintragen
    </MudButton>
</MudPaper>

@if (_dataLoading)
{
    <MudPaper Class="mud-theme-dark pa-4 ma-4" Elevation="1">
        <MudProgressLinear Color="Color.Primary" Indeterminate="true"/>
    </MudPaper>
}
else
{
    <div class="@(_students.Count == 0 ? "d-none" : "")">
        <MudPaper Class="mud-theme-dark pa-4 ma-4" Elevation="1">
            <MudDataGrid 
                @ref="_mudDataGrid" 
                Items="@_students" 
                Bordered="false"
                Dense="true"
                RowsPerPage="10"
                SortMode="SortMode.Multiple"
                Hover="true"
                Loading="@_dataLoading"
            >
                <Columns>
                    <PropertyColumn Property="x => x.Id" Title="ID" />
                    <PropertyColumn Property="x => x.FirstName" Title="Vorname" />
                    <PropertyColumn Property="x => x.LastName" Title="Nachname" />
                    <PropertyColumn Property="x => x.Mail" Title="E-Mail" />
                    <PropertyColumn Property="x => x.Phone" Title="Telefon" />
                    <TemplateColumn Title="Fahrschule">
                        <CellTemplate>
                            <MudChip T="string"
                                     Size="Size.Medium"
                                     Variant="Variant.Text"
                                     Color="@(context.Item.DrivingSchoolId > 0 ? Color.Info : Color.Error)">
                                @GetDrivingSchoolName(context.Item.DrivingSchoolId)
                            </MudChip>
                        </CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn Title="Aktiv">
                        <CellTemplate>
                            <MudChip T="string"
                                     Size="Size.Medium"
                                     Variant="Variant.Text"
                                     Color="@(context.Item.IsActive ? Color.Success : Color.Error)">
                                @(context.Item.IsActive ? "Ja" : "Nein")
                            </MudChip>
                        </CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn>
                        <CellTemplate>
                            <MudIconButton
                                Variant="Variant.Outlined"
                                Color="Color.Warning"
                                Size="Size.Small"
                                Icon="@Icons.Material.Filled.Edit"
                                OnClick="() => OnShowEditModal(context.Item)"
                                Class="mr-2"
                                aria-label="Bearbeiten" />
                            <MudIconButton
                                Variant="Variant.Outlined"
                                Color="Color.Error"
                                Size="Size.Small"
                                Icon="@Icons.Material.Filled.Delete"
                                OnClick="() => OnShowDeleteModal(context.Item)"
                                aria-label="Löschen" />
                        </CellTemplate>
                    </TemplateColumn>
                </Columns>
                <PagerContent>
                    <MudDataGridPager />
                </PagerContent>
            </MudDataGrid>
        </MudPaper>
    </div>
    
    @if (_students.Count == 0)
    {
        <MudPaper Class="mud-theme-dark pa-4 ma-4" Elevation="1">
            <MudAlert Severity="Severity.Info" ContentAlignment="HorizontalAlignment.Center">Keine Daten vorhanden.</MudAlert>
        </MudPaper>
    }
}

<MudDialog @ref="_createDialog">
    <TitleContent>
        <MudText Typo="Typo.h6">Fahrschüler anlegen</MudText>
    </TitleContent>
    <DialogContent>
        <MudPaper Class="mud-theme-dark pa-4" Elevation="1">
            <MudTextField AutoFocus="true" Class="mb-4" ShrinkLabel @bind-Value="_newStudent.FirstName" Label="Vorname" Variant="Variant.Text"/>
            <MudTextField Class="mb-4" ShrinkLabel @bind-Value="_newStudent.LastName" Label="Nachname" Variant="Variant.Text"/>
            <MudTextField Class="mb-4" ShrinkLabel @bind-Value="_newStudent.Mail" Label="E-Mail" Variant="Variant.Text"/>
            <MudTextField Class="mb-4" ShrinkLabel @bind-Value="_newStudent.Phone" Label="Telefon" Variant="Variant.Text"/>
            <MudSelect
                Class="mb-4"
                @bind-Value="_newStudent.IsActive"
                Variant="Variant.Text"
                Label="Aktiv"
                Placeholder="Aktiv-Status wählen">
                <MudSelectItem Value="true">Aktiv</MudSelectItem>
                <MudSelectItem Value="false">Inaktiv</MudSelectItem>
            </MudSelect>
            <MudSelect
                Class="mb-4"
                @bind-Value="_newStudent.DrivingSchoolId"
                Variant="Variant.Text"
                Label="Fahrschule zuweisen"
                Disabled="!_drivingSchools.Any()"
                Placeholder="Fahrschule wählen">
                @foreach (var school in _drivingSchools)
                {
                    <MudSelectItem Value="@((int?)school.Id)">@school.Name</MudSelectItem>
                }
            </MudSelect>
        </MudPaper>
    </DialogContent>
    <DialogActions>
        <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Error" OnClick="() => OnHideModal(_createDialog)">Abbrechen</MudButton>
        <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Secondary" OnClick="HandleCreateDriverAsync">Eintragen</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @ref="_editDialog">
    <TitleContent>
        <MudText Typo="Typo.h6">Fahrschüler bearbeiten</MudText>
    </TitleContent>
    <DialogContent>
        <MudPaper Class="mud-theme-dark pa-4" Elevation="1">
            <MudTextField AutoFocus="true" Class="mb-4" ShrinkLabel @bind-Value="_editStudent!.FirstName" Label="Vorname" Variant="Variant.Text"/>
            <MudTextField Class="mb-4" ShrinkLabel @bind-Value="_editStudent!.LastName" Label="Nachname" Variant="Variant.Text"/>
            <MudTextField Class="mb-4" ShrinkLabel @bind-Value="_editStudent!.Mail" Label="E-Mail" Variant="Variant.Text"/>
            <MudTextField Class="mb-4" ShrinkLabel @bind-Value="_editStudent!.Phone" Label="Telefon" Variant="Variant.Text"/>
            <MudSelect
                Class="mb-4"
                @bind-Value="_editStudent!.IsActive"
                Variant="Variant.Text"
                Label="Aktiv"
                Placeholder="Aktiv-Status wählen">
                <MudSelectItem Value="true">Aktiv</MudSelectItem>
                <MudSelectItem Value="false">Inaktiv</MudSelectItem>
            </MudSelect>
            <MudSelect
                Class="mb-4"
                @bind-Value="_editStudent!.DrivingSchoolId"
                Variant="Variant.Text"
                Label="Fahrschule zuweisen"
                Disabled="!_drivingSchools.Any()"
                Placeholder="Fahrschule wählen">
                @foreach (var school in _drivingSchools)
                {
                    <MudSelectItem Value="@((int?)school.Id)">@school.Name</MudSelectItem>
                }
            </MudSelect>
        </MudPaper>
    </DialogContent>
    <DialogActions>
        <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Error" OnClick="() => OnHideModal(_editDialog)">Abbrechen</MudButton>
        <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Secondary" OnClick="ConfirmEditDrivingSchoolAsync">Änderungen speichern</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @ref="_deleteDialog">
    <TitleContent>
        <MudText Typo="Typo.h6">Fahrschüler löschen</MudText>
    </TitleContent>
    <DialogContent>
        <MudPaper Class="mud-theme-dark pa-4" Elevation="1">
            <MudText>Bist du sicher, dass du die Fahrschüler @_editStudent?.FullName löschen möchtest?</MudText>
        </MudPaper>
    </DialogContent>
    <DialogActions>
        <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Error" OnClick="() => OnHideModal(_deleteDialog)">Nein</MudButton>
        <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Secondary" OnClick="OnRequestDeleteDriverAsync">Ja</MudButton>
    </DialogActions>
</MudDialog>